{
  "buildCommand": null,
  "outputDirectory": "app",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "redirects": [
    { "source": "/workspace", "destination": "/index.html", "statusCode": 302 }
  ]
}
